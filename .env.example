# Copy to .env and customize

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=your-very-secret-key-here

# Admin user initial password
ADMIN_PASSWORD=admin123

# Server listen address and port
HOST=127.0.0.1
PORT=5000

# URL secret prefix (auto-generated on first start if left empty)
# API_PREFIX=your-random-secret-path

# LXD socket path
# LXD_SOCKET=/var/lib/incus/unix.socket        # Incus
# LXD_SOCKET=/var/snap/lxd/common/lxd/unix.socket  # LXD snap

# Debug mode
DEBUG=false
